  <!-- Run Tests -->
  <configuration default="false" name="Pytest" type="PythonConfigurationType" factoryName="Python">
    <module name="network-intelligence" />
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$" />
    <option name="SCRIPT_NAME" value="" />
