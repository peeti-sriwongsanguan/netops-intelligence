<component name="ProjectRunConfigurationManager">

  <!-- Run Flask Dev Server -->
  <configuration default="false" name="Flask Dev Server" type="PythonConfigurationType" factoryName="Python">
    <module name="network-intelligence" />
    <option name="INTERPRETER_OPTIONS" value="" />
    <option name="PARENT_ENVS" value="true" />
    <envs>
      <env name="FLASK_ENV" value="development" />
      <env name="PYTHONUNBUFFERED" value="1" />
    </envs>
    <option name="SDK_HOME" value="" />
    <option name="WORKING_DIRECTORY" value="$PROJECT_DIR$" />
    <option name="SCRIPT_NAME" value="$PROJECT_DIR$/run.py" />
